# Copy to .env and fill in real values. Loaded by test_app.py via python-dotenv,
# or by AIRSGuardedChatModel directly when constructed with load_dotenv=True
# (or dotenv_path=...).

# Prisma AIRS scan API key. One of api_key / api_token is required by the SDK.
PANW_AI_SEC_API_KEY=your-airs-key-here

# Alternative to PANW_AI_SEC_API_KEY for token-based auth. Optional.
# PANW_AI_SEC_API_TOKEN=your-airs-token-here

# AIRS API endpoint override. Optional; only set if your tenant uses a
# non-default region/host.
# PANW_AI_SEC_API_ENDPOINT=https://service.api.aisecurity.paloaltonetworks.com

# Anthropic key for the inner LLM (ChatAnthropic in the demo). Required.
ANTHROPIC_API_KEY=sk-ant-...

# AIRS profile name from Strata Cloud Manager. Required.
AIRS_PROFILE_NAME=your-airs-profile-name
