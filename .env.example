# Copy to .env and fill in real values. Loaded by test_app.py via python-dotenv.

# Prisma AIRS scan API key (or PANW_AI_SEC_API_TOKEN). Required.
PANW_AI_SEC_API_KEY=your-airs-key-here

# Anthropic key for the inner LLM (ChatAnthropic in the demo). Required.
ANTHROPIC_API_KEY=sk-ant-...

# AIRS profile name from Strata Cloud Manager. Required.
AIRS_PROFILE_NAME=your-airs-profile-name
